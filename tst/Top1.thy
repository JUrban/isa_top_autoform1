	                    have "z \<le> yB b"
	                      by (rule order_trans[OF hzb1 True])
	                    have "yB b < yB b"
	                      by (rule less_le_trans[OF hzb2 \<open>z \<le> yB b\<close>])
	                    thus ?thesis by simp
	                  next
	                    case False
		                    have hyb_a: "yB b < a"
