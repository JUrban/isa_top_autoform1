            have hs: "a < ?plus p"
              using hs_in unfolding open_ray_gt_def by simp
            define s where "s = ?plus p"
            define e where "e = (s - a) / 4"
            have he_pos: "0 < e"
              unfolding e_def using hs unfolding s_def by (simp add: divide_pos_pos)

