	            define U where "U = (\<Union>a\<in>A. {xA a <.. a})"
	            define V where "V = (\<Union>b\<in>B. {yB b <.. b})"

            have hUopen: "U \<in> ?T"
            proof -
	              have hFam: "{{xA a <.. a} | a. a \<in> A} \<subseteq> ?T"
